# Neon PostgreSQL — get these values from the Neon dashboard "Connect" dialog
# See the "Environment Variables" section in the README for details

# Pooled connection, used by the application at runtime
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require"

# Direct connection, used by Prisma Migrate
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"